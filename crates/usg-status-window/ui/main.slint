import { Spinner, Button } from "std-widgets.slint";

// One centered "Label: value" detail row (label right-aligned, value left).
component Field inherits HorizontalLayout {
    in property <string> label;
    in property <string> value;
    spacing: 10px;
    Text {
        text: root.label + ":";
        color: #c2d4ea;
        font-size: 13px;
        width: 190px;
        horizontal-alignment: right;
        vertical-alignment: center;
    }
    Text {
        text: root.value;
        color: white;
        font-size: 13px;
        font-weight: 600;
        width: 220px;
        horizontal-alignment: left;
        vertical-alignment: center;
        overflow: elide;
    }
}

// A labeled certificate block: caption, the full DN wrapped, and a View button.
component CertBlock inherits VerticalLayout {
    in property <string> caption;
    in property <string> subject;
    in property <bool> available;
    callback view();
    spacing: 3px;
    Text {
        text: root.caption;
        color: #c2d4ea;
        font-size: 13px;
        horizontal-alignment: center;
    }
    Text {
        text: root.subject;
        color: white;
        font-size: 13px;
        font-weight: 600;
        horizontal-alignment: center;
        wrap: word-wrap;
    }
    HorizontalLayout {
        alignment: center;
        padding-top: 2px;
        Button {
            text: "View…";
            enabled: root.available;
            clicked => {
                root.view();
            }
        }
    }
}

export component MainWindow inherits Window {
    title: "USG Supplicant — Authentication Status";
    width: 560px;
    height: 560px;
    background: #355e93;
    icon: root.seal;

    // Set from Rust on a poll timer.
    in property <image> logo;
    in property <image> seal;
    in property <string> headline: "—";
    in property <string> session: "—";
    in property <string> outer: "—";
    in property <string> inner: "—";
    in property <string> machine-cert: "—";
    in property <string> user-cert: "—";
    in property <bool> has-machine-cert: false;
    in property <bool> has-user-cert: false;
    in property <string> server: "—";
    in property <string> detail: "";
    in property <string> updated: "—";
    // 0 idle/unknown · 1 in-progress · 2 authenticated · 3 failed
    in property <int> indicator: 0;

    // Fired by the per-certificate "View…" buttons.
    callback view-computer-cert();
    callback view-user-cert();

    VerticalLayout {
        // Header banner: the U.S. Department of War logo across the top.
        Image {
            source: root.logo;
            image-fit: contain;
            height: 120px;
        }

        VerticalLayout {
            padding-left: 24px;
            padding-right: 24px;
            padding-bottom: 22px;
            spacing: 14px;

            // Headline + status indicator, centered.
            HorizontalLayout {
                alignment: center;
                spacing: 12px;
                Rectangle {
                    width: 30px;
                    height: 30px;
                    if root.indicator == 1: Spinner {
                        width: 28px;
                        height: 28px;
                        indeterminate: true;
                    }
                    if root.indicator != 1: Rectangle {
                        width: 22px;
                        height: 22px;
                        border-radius: 11px;
                        background: root.indicator == 2 ? #43a047
                            : root.indicator == 3 ? #e53935
                            : #8a8a8a;
                    }
                }
                Text {
                    text: root.headline;
                    color: white;
                    font-size: 24px;
                    font-weight: 700;
                    vertical-alignment: center;
                }
            }

            Rectangle {
                height: 1px;
                background: #4d74a6;
            }

            // Status rows, centered as a block.
            HorizontalLayout {
                alignment: center;
                VerticalLayout {
                    spacing: 7px;
                    Field { label: "Session"; value: root.session; }
                    Field { label: "Outer (TEAP tunnel)"; value: root.outer; }
                    Field { label: "Inner (EAP-TLS)"; value: root.inner; }
                    Field { label: "Server"; value: root.server; }
                    Field { label: "Updated"; value: root.updated; }
                    if root.detail != "": Field { label: "Detail"; value: root.detail; }
                }
            }

            // Both credentials: the computer (machine) cert and the user cert.
            VerticalLayout {
                spacing: 14px;
                vertical-stretch: 1;
                CertBlock {
                    caption: "Computer certificate";
                    subject: root.machine-cert;
                    available: root.has-machine-cert;
                    view => {
                        root.view-computer-cert();
                    }
                }
                CertBlock {
                    caption: "User certificate";
                    subject: root.user-cert;
                    available: root.has-user-cert;
                    view => {
                        root.view-user-cert();
                    }
                }
            }
        }
    }
}
